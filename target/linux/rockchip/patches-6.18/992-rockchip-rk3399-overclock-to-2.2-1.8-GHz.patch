From: coolsnowwolf <coolsnowwolf@gmail.com>
Subject: [PATCH] rockchip: rk3399: overclock to 2.2/1.8 GHz

Add the shared RK3399 OPP table used by local board device trees and
enable the same table for the NanoPi4 family.

Signed-off-by: coolsnowwolf <coolsnowwolf@gmail.com>
---

--- /dev/null
+++ b/arch/arm64/boot/dts/rockchip/rk3399-opp.dtsi
@@ -0,0 +1,26 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+/*
+ * Copyright (c) 2016-2017 Fuzhou Rockchip Electronics Co., Ltd
+ */
+
+#include "rk3399-op1.dtsi"
+
+/ {
+	cluster0_opp: opp-table-0 {
+		opp07 {
+			opp-hz = /bits/ 64 <1608000000>;
+			opp-microvolt = <1225000 1225000 1225000>;
+		};
+		opp08 {
+			opp-hz = /bits/ 64 <1800000000>;
+			opp-microvolt = <1275000 1275000 1275000>;
+		};
+	};
+
+	cluster1_opp: opp-table-1 {
+		opp09 {
+			opp-hz = /bits/ 64 <2208000000>;
+			opp-microvolt = <1325000 1325000 1325000>;
+		};
+	};
+};
--- a/arch/arm64/boot/dts/rockchip/rk3399-nanopi4.dtsi
+++ b/arch/arm64/boot/dts/rockchip/rk3399-nanopi4.dtsi
@@ -14,6 +14,7 @@
 /dts-v1/;
 #include <dt-bindings/input/linux-event-codes.h>
 #include "rk3399.dtsi"
+#include "rk3399-opp.dtsi"
 
 / {
 	aliases {
