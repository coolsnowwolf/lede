+#include <linux/dsa/8021q.h>
 #include <net/dsa.h>
 
 #include "mxl862xx.h"
@@ -88,6 +89,9 @@ enum mxl862xx_evlan_action {
 	EVLAN_STRIP_IF_UNTAGGED,	/* remove 1 tag if entry's untagged flag set */
 	EVLAN_PVID_OR_DISCARD,		/* insert PVID tag or discard if no PVID */
