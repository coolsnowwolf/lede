+	struct mxl862xx_priv *priv;
+	u16 fid;
+	unsigned long flood_block;
+	bool learning;
+	bool setup_done;
+	bool host_flood_uc;
+	bool host_flood_mc;
+	struct work_struct host_flood_work;
+};
 
+/**
